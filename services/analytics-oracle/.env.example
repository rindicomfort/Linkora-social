DATABASE_URL=postgres://postgres:postgres@localhost:5432/linkora
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=
# Hex-encoded Ed25519 private key (32 bytes). Generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ORACLE_PRIVATE_KEY_HEX=
ORACLE_NAME=default
# How many ledgers between analytics computation runs (~1000 ledgers ≈ 83 min at 5s/ledger)
WINDOW_LEDGERS=1000
PORT=4000
